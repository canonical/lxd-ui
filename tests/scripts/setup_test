#! /usr/bin/env bash
set -e

EXEC=""
if [ "$DEPLOYMENT" = "clustered" ]; then
    echo "Configuring clustered environment via vm1..."
    EXEC="sudo lxc exec vm1 -- "
fi

# Function to set config by trying every known naming convention
smart_set() {
    local key=$1
    local value=$2
    # Try the 3 known prefixes. If one works, we stop.
    $EXEC lxc config set "auth.idp.${key}" "${value}" 2>/dev/null || \
    $EXEC lxc config set "oidc.${key}" "${value}" 2>/dev/null || \
    $EXEC lxc config set "${key}" "${value}" 2>/dev/null || \
    echo "Warning: Could not set ${key}, but continuing..."
}

# Apply OIDC settings
smart_set "issuer" "${LXD_OIDC_ISSUER}"
smart_set "client.id" "${LXD_OIDC_CLIENT_ID}"
smart_set "audience" "${LXD_OIDC_AUDIENCE}"
smart_set "groups.claim" "${LXD_OIDC_GROUPS_CLAIM}"

# Logic for Secret (Only if the extension exists)
if $EXEC lxc info | grep -q "oidc_client_secret"; then
    smart_set "client.secret" "${LXD_OIDC_CLIENT_SECRET}"
fi

# Auth groups
$EXEC lxc auth group create login-admin || true
$EXEC lxc auth group permission add login-admin server admin || true
$EXEC lxc auth identity-provider-group create admin || true
$EXEC lxc auth identity-provider-group group add admin login-admin || true

# SQL - Ensure we don't fail if the user already exists
$EXEC lxd sql global "INSERT OR REPLACE INTO identities (auth_method, type, identifier, name, metadata) VALUES (2, 5, 'foo@foo.com', 'foo', '{}');" || true
$EXEC lxd sql global "INSERT OR REPLACE INTO identities (auth_method, type, identifier, name, metadata) VALUES (2, 5, 'bar@bar.com', 'bar', '{}');" || true

# THE RESTART: Forces discovery before Playwright starts
echo "Restarting LXD to force OIDC discovery..."
$EXEC snap restart lxd
sleep 20
